<?xml version="1.0"?>
<robot name="challenge_rover">
    <link name="base_footprint"/>
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.4 0.3 0.15"/>
            </geometry>
            <material name="blue">
                <color rgba="0.2 0.2 0.8 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.4 0.3 0.15"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="4.0"/>
            <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.06" iyz="0.0" izz="0.08"/>
        </inertial>
    </link>

    <link name="fl_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
        </inertial>
    </link>
    <joint name="fl_joint" type="continuous">
        <parent link="base_link"/>
        <child link="fl_wheel"/>
        <origin xyz="0.15 0.175 -0.05" rpy="1.5708 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>
    <link name="fr_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
        </inertial>
    </link>
    <joint name="fr_joint" type="continuous">
        <parent link="base_link"/>
        <child link="fr_wheel"/>
        <origin xyz="0.15 -0.175 -0.05" rpy="1.5708 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>
    <link name="rl_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
        </inertial>
    </link>
    <joint name="rl_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rl_wheel"/>
        <origin xyz="-0.15 0.175 -0.05" rpy="1.5708 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>
    <link name="rr_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
        </inertial>
    </link>
    <joint name="rr_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rr_wheel"/>
        <origin xyz="-0.15 -0.175 -0.05" rpy="1.5708 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="pillar_fl">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="pillar_fl_joint" type="fixed">
        <parent link="base_link"/>
        <child link="pillar_fl"/>
        <origin xyz="0.15 0.12 0.125" rpy="0 0 0"/>
    </joint>
    <link name="pillar_fr">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="pillar_fr_joint" type="fixed">
        <parent link="base_link"/>
        <child link="pillar_fr"/>
        <origin xyz="0.15 -0.12 0.125" rpy="0 0 0"/> 
    </joint>
    <link name="pillar_rl">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="pillar_rl_joint" type="fixed">
        <parent link="base_link"/>
        <child link="pillar_rl"/>
        <origin xyz="-0.15 0.12 0.125" rpy="0 0 0"/>
    </joint>
    <link name="pillar_rr">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="pillar_rr_joint" type="fixed">
        <parent link="base_link"/>
        <child link="pillar_rr"/>
        <origin xyz="-0.15 -0.12 0.125" rpy="0 0 0"/> 
    </joint>
    <link name="top_deck">
        <visual>
            <geometry>
                <box size="0.4 0.3 0.02"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.4 0.3 0.02"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.005"/>
        </inertial>
    </link>
    <joint name="deck_joint" type="fixed">
        <parent link="base_link"/>
        <child link="top_deck"/>
        <origin xyz="0 0 0.185" rpy="0 0 0"/>
    </joint>

    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.04 0.04 0.02"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0.085" rpy="0 0 0"/>
    </joint>
    <link name="gps_link">
        <visual>
            <geometry>
                <cylinder radius="0.03" length="0.02"/>
            </geometry>
            <material name="green">
                <color rgba="0 1 0 1"/>
            </material>
        </visual>
    </link>
    <joint name="gps_joint" type="fixed">
        <parent link="top_deck"/>
        <child link="gps_link"/>
        <origin xyz="0.08 -0.08 0.02" rpy="0 0 0"/>
    </joint>

    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.06" length="0.12"/>
            </geometry>
            <material name="cyan">
                <color rgba="0.0 1.0 1.0 1.0"/> 
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.06" length="0.12"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>
    <joint name="lidar_joint" type="fixed">
        <parent link="top_deck"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.07" rpy="0 0 0"/>
    </joint>

    <gazebo>
        <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
            <left_joint>
                fl_joint
            </left_joint>
            <left_joint>
                rl_joint
            </left_joint>
            <right_joint>
                fr_joint
            </right_joint>
            <right_joint>
                rr_joint
            </right_joint>

            <wheel_separation>
                0.35
            </wheel_separation>
            <wheel_radius> 
                0.08
            </wheel_radius>
            <topic>
                /cmd_vel
            </topic>
            <odom_topic>
                /odom
            </odom_topic>
            <tf_topic>
                /model/challenge_rover/tf
            </tf_topic>
            <odom_publish_frequency>
                40
            </odom_publish_frequency>
            <frame_id>
                odom
            </frame_id>
            <child_frame_id>
                base_footprint
            </child_frame_id>
        </plugin>
    </gazebo>
    
    <gazebo reference="lidar_link">
        <sensor name="lidar" type="gpu_lidar">
            <gz_frame_id>
                lidar_link
            </gz_frame_id>
            <pose>
                0 0 0 0 0 0
            </pose>
            <topic>
                /scan
            </topic>
            <update_rate>
                8
            </update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>
                            360
                        </samples>
                        <resolution>
                            1
                        </resolution>
                        <min_angle>
                            -3.14159
                        </min_angle>
                        <max_angle>
                            3.14159
                        </max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>
                        0.1
                    </min>
                    <max>
                        10.0
                    </max>
                    <resolution>
                        0.01
                    </resolution>
                </range>
            </ray>
            <always_on>
                true
            </always_on>
            <visualize>
                true
            </visualize>
        </sensor>
    </gazebo>

    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>
                true
            </always_on>
            <update_rate>
                50
            </update_rate>
            <topic>
                /imu
            </topic>
            <gz_frame_id>
                imu_link
            </gz_frame_id>
        </sensor>
    </gazebo>
    
    <gazebo reference="fl_wheel">
        <mu1>
            0.8
        </mu1>
        <mu2>
            0.10
        </mu2>
        <fdir1>
            1 0 0
        </fdir1>
        <minDepth>
            0.001
        </minDepth> 
    </gazebo>
    
    <gazebo reference="fr_wheel">
        <mu1>
            0.8
        </mu1>
        <mu2>
            0.10
        </mu2>
        <fdir1>
            1 0 0
        </fdir1>
        <minDepth>
            0.001
        </minDepth>
    </gazebo>
    
    <gazebo reference="rl_wheel">
        <mu1>
            0.8
        </mu1>
        <mu2>
            0.10
        </mu2>
        <fdir1>
            1 0 0
        </fdir1>
        <minDepth>
            0.001
        </minDepth>
    </gazebo>
    
    <gazebo reference="rr_wheel">
        <mu1>
            0.8
        </mu1>
        <mu2>
            0.10
        </mu2>
        <fdir1>
            1 0 0
        </fdir1>
        <minDepth>
            0.001
        </minDepth>
    </gazebo>

    <gazebo>
        <plugin
            filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
            <topic>
                /joint_states
            </topic>
            <joint_name>
                fl_joint
            </joint_name>
            <joint_name>
                fr_joint
            </joint_name>
            <joint_name>
                rl_joint
            </joint_name>
            <joint_name>
                rr_joint
            </joint_name>
        </plugin>
    </gazebo>
</robot>