        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="pillar_fl_joint" type="fixed">
        <parent link="base_link"/>
        <child link="pillar_fl"/>
        <origin xyz="0.15 0.12 0.125" rpy="0 0 0"/>
    </joint>

    <link name="pillar_fr">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="pillar_fr_joint" type="fixed">
        <parent link="base_link"/>
        <child link="pillar_fr"/>
        <origin xyz="0.15 -0.12 0.125" rpy="0 0 0"/> 
    </joint>

    <link name="pillar_rl">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    <joint name="pillar_rl_joint" type="fixed">
        <parent link="base_link"/>
        <child link="pillar_rl"/>
        <origin xyz="-0.15 0.12 0.125" rpy="0 0 0"/>
    </joint>

    <link name="pillar_rr">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.1"/>
