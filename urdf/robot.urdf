<?xml version="1.0"?>
<robot name="challenge_rover">

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.4 0.3 0.15"/>
            </geometry>
            <material name="blue">
                <color rgba="0.2 0.2 0.8 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.4 0.3 0.15"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="4.0"/>
            <inertia ixx="0.03" ixy="0.0" ixz="0.0" iyy="0.06" iyz="0.0" izz="0.08"/>
        </inertial>
    </link>

    <link name="fl_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
        </inertial>
    </link>
    <joint name="fl_joint" type="continuous">
        <parent link="base_link"/>
        <child link="fl_wheel"/>
        <origin xyz="0.15 0.175 -0.05" rpy="1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="fr_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
        </inertial>
    </link>
    <joint name="fr_joint" type="continuous">
        <parent link="base_link"/>
        <child link="fr_wheel"/>
        <origin xyz="0.15 -0.175 -0.05" rpy="1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="rl_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
        </inertial>
    </link>
    <joint name="rl_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rl_wheel"/>
        <origin xyz="-0.15 0.175 -0.05" rpy="1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="rr_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
