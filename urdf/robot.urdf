    </joint>

    <link name="top_deck">
        <visual>
            <geometry>
                <box size="0.4 0.3 0.02"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.4 0.3 0.02"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.005"/>
        </inertial>
    </link>
    <joint name="deck_joint" type="fixed">
        <parent link="base_link"/><child link="top_deck"/>
        <origin xyz="0 0 0.185" rpy="0 0 0"/> </joint>
        <link name="imu_link">
            <visual>
                <geometry>
                    <box size="0.04 0.04 0.02"/>
                </geometry>
                <material name="red">
                    <color rgba="1 0 0 1"/>
                </material>
            </visual>
        </link>
        <joint name="imu_joint" type="fixed">
            <parent link="base_link"/>
            <child link="imu_link"/>
            <origin xyz="0 0 0.085" rpy="0 0 0"/>
        </joint>
        <link name="gps_link">
            <visual>
                <geometry>
                    <cylinder radius="0.03" length="0.02"/>
                </geometry>
                <material name="green">
                    <color rgba="0 1 0 1"/>
                </material>
            </visual>
        </link>
    <joint name="gps_joint" type="fixed">
        <parent link="top_deck"/>
        <child link="gps_link"/>
        <origin xyz="0.08 -0.08 0.02" rpy="0 0 0"/>
    </joint>

    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.06" length="0.12"/>
            </geometry>
            <material name="cyan_terang">
                <color rgba="0.0 1.0 1.0 1.0"/> 
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.06" length="0.12"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
